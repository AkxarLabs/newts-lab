# Spawned project repos live OUTSIDE the hub at lab.projects_root (default
# ../kartr-lab-projects), so they're normally not in this tree at all. These
# entries are a SAFETY NET: if the PI points lab.projects_root at a path INSIDE the
# hub, the project repos (each its own git repo, with its own large runs/) must not
# be committed into the hub. The hub only ever tracks studies/<slug>/ (idea + paper/).
/kartr-lab-projects/
/projects/
/Projects/

# Docs build output (ProperDocs)
site/

# Runtime compute-slot ledger (tools/run_slots.py)
lab/.slots/

# Dashboard event bus + directive inbox (tools/lab_bus.py, dashboard/)
lab/.bus/

# Dashboard SOURCE art (raw generations / previews) — provenance only, never served, large.
# The RUNTIME art the page actually loads lives in dashboard/static/assets/ and IS committed.
dashboard/assets-src/

# Python
__pycache__/
*.pyc
.venv/

# Hub-tools test suite runtime (pytest --basetemp=.pytmp; cwd-relative, so match it anywhere)
.pytmp/
.pytest_cache/

# LaTeX build artifacts (papers live at studies/<slug>/paper/)
studies/**/*.aux
studies/**/*.bbl
studies/**/*.blg
studies/**/*.fdb_latexmk
studies/**/*.fls
studies/**/*.log
studies/**/*.out
studies/**/*.synctex.gz

# OS
.DS_Store
Thumbs.db

# Machine-local Claude Code settings
.claude/settings.local.json
